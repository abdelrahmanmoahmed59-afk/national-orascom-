# Admin dashboard auth (required for /admin and /api/admin/*)
# Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-this-to-a-long-random-string"
ADMIN_USERNAME="admin"
# Generate with: node scripts/hash-admin-password.mjs "your-password"
# Copy the full `ADMIN_PASSWORD_HASH="..."` line it prints (it escapes `$` for Next.js env expansion).
ADMIN_PASSWORD_HASH="scrypt$<salt-base64>$<key-base64>"
